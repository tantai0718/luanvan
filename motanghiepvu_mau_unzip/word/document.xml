w:bCs/><w:color w:val="EE0000"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr></w:pPr><w:r w:rsidRPr="00F15BAF"><w:rPr><w:rFonts w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:color w:val="EE0000"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr><w:t>Mô tả nghiệp vụ:</w:t></w:r></w:p><w:p w14:paraId="5717EE03" w14:textId="77777777" w:rsidR="000A017D" w:rsidRPr="007070FB" w:rsidRDefault="000A017D" w:rsidP="000A017D"><w:pPr><w:pStyle w:val="NormalWeb"/><w:spacing w:before="0" w:beforeAutospacing="0" w:after="0" w:afterAutospacing="0" w:line="360" w:lineRule="auto"/><w:ind w:firstLine="720"/><w:jc w:val="both"/><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">Đề tài </w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>“</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Xây dựng ứng dụng hỗ trợ đặt vé xe khách và khách sạn</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>”</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> được định hướng triển khai giai đoạn đầu tại các đô thị trọng điểm có mật độ giao thương và du lịch cao như TP. Hồ Chí Minh, Hà Nội, Đà Nẵng,</w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> Vũng Tàu</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> cùng các khu nghỉ dưỡng và danh lam thắng cảnh nổi tiếng. Nền tảng ưu tiên thiết lập mạng lưới đối tác với các cơ sở lưu trú có vị trí thuận lợi, chất lượng dịch vụ tốt nhằm đáp ứng đa dạng phân khúc khách hàng, tạo tiền đề để mở rộng phạm vi hoạt động trên toàn quốc trong tương lai. Điểm nhấn trọng tâm của hệ thống nằm ở việc kết hợp xuyên suốt hai dịch vụ lưu trú và di chuyển</w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>.</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>H</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>ỗ trợ người dùng tìm kiếm, đặt vé xe khách đồng bộ với lịch trình nhận phòng khách sạn, từ đó mang lại một giải pháp du lịch toàn diện.</w:t></w:r></w:p><w:p w14:paraId="4C12C3C1" w14:textId="77777777" w:rsidR="000A017D" w:rsidRPr="007070FB" w:rsidRDefault="000A017D" w:rsidP="000A017D"><w:pPr><w:pStyle w:val="NormalWeb"/><w:spacing w:before="0" w:beforeAutospacing="0" w:after="0" w:afterAutospacing="0" w:line="360" w:lineRule="auto"/><w:ind w:firstLine="720"/><w:jc w:val="both"/><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Hệ thống được vận hành theo mô hình ứng dụng trung gian, phục vụ hai nhóm đối tượng chính. Đối với khách hàng cá nhân, ứng dụng mang đến trải nghiệm tìm kiếm, so sánh và đặt phòng cùng</w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> với đặt</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> vé xe một cách nhanh chóng, tiện lợi với luồng thanh toán trực tuyến an toàn. Đối với các đối tác kinh doanh lưu t</w:t></w:r><w:r><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>rú</w:t></w:r><w:r w:rsidRPr="007070FB"><w:rPr><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>, hệ thống cung cấp một không gian quản trị số hóa giúp họ dễ dàng quản lý tình trạng phòng trống, cập nhật giá cả, xử lý đơn hàng và theo dõi báo cáo doanh thu trực quan.</w:t></w:r></w:p><w:p w14:paraId="3EC9A8C0" w14:textId="77777777" w:rsidR="000A017D" w:rsidRPr="00F15BAF" w:rsidRDefault="000A017D" w:rsidP="000A017D"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:spacing w:after="0" w:line="360" w:lineRule="auto"/><w:ind w:left="426"/><w:jc w:val="both"/><w:rPr><w:rFonts w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:color w:val="EE0000"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr></w:pPr><w:r w:rsidRPr="00F15BAF"><w:rPr><w:rFonts w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:color w:val="EE0000"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr><w:t>Các chức năng chính của hệ thống</w:t></w:r></w:p><w:p w14:paraId="595BB5C0" w14:textId="77777777" w:rsidR="000A017D" w:rsidRDefault="000A017D" w:rsidP="000A017D"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:spacing w:after="0" w:line="360" w:lineRule="auto"/><w:jc w:val="both"/><w:rPr><w:rFonts w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr></w:pPr><w:r w:rsidRPr="00F15BAF"><w:rPr><w:rFonts w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:color w:val="EE0000"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr><w:t>Khách hàng</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr><w:t>:</w:t></w:r></w:p><w:p w14:paraId="2E586516" w14:textId="77777777" w:rsidR="000A017D" w:rsidRDefault="000A017D" w:rsidP="000A017D"><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:spacing w:after="0" w:line="360" w:lineRule="auto"/><w:jc w:val="both"/><w:rPr><w:rFonts w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr